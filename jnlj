/* ===== STICKY HEADER ===== */
.top-header {
    background: #4a4a4a;
    padding: 12px 0;
    position: sticky;
    top: 0;
    z-index: 1000;
    box-shadow: 0 2px 15px rgba(0, 0, 0, 0.2);
    transition: all 0.3s ease;
}

.logo-section {
    display: flex;
    align-items: center;
    gap: 8px;
}

.logo-icon {
    font-size: 24px;
    color: #e0e0e0;
}

.logo-text {
    font-size: 18px;
    font-weight: 800;
    color: #e0e0e0;
    margin: 0;
}

.search-container {
    width: 100%;
    position: relative;
}

.search-input {
    width: 100%;
    padding: 10px 16px 10px 42px;
    border: none;
    border-radius: 50px;
    background: #f8f8f8;
    font-size: 13px;
    font-weight: 500;
    transition: background 0.3s, color 0.3s;
}

.search-input:focus {
    outline: none;
    box-shadow: 0 0 0 3px rgba(160, 160, 160, 0.4);
}

.search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: #8b8b8b;
}

.header-icons {
    display: flex;
    gap: 16px;
    align-items: center;
    justify-content: flex-end;
    position: relative;
}

.header-icons i {
    font-size: 20px;
    color: #e0e0e0;
    cursor: pointer;
    transition: 0.2s;
}

.header-icons i:hover {
    color: #F7C81A;
}

.dark-mode-toggle {
    background: none;
    border: none;
    color: #e0e0e0;
    font-size: 20px;
    cursor: pointer;
    padding: 0;
    transition: 0.2s;
}

.dark-mode-toggle:hover {
    color: #F7C81A;
}

.cart-btn {
    cursor: pointer;
    position: relative;
}

.cart-count-badge {
    position: absolute;
    top: -8px;
    right: -12px;
    background: #F7C81A;
    color: #2d2d2d;
    font-size: 10px;
    font-weight: 800;
    border-radius: 50%;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
}

/* ===== STICKY NAV ===== */
.nav-menu {
    background: #fff;
    border-bottom: 2px solid #f0f0f0;
    padding: 0;
    position: sticky;
    top: 72px;
    z-index: 999;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: all 0.3s ease;
}

.nav-menu.scrolled {
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.12);
}

.nav-list {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0;
    flex-wrap: wrap;
}

.nav-list li a {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 24px;
    color: #4a4a4a;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    border-bottom: 3px solid transparent;
    transition: 0.2s;
}

.nav-list li a:hover {
    background: #f5f5f5;
    color: #2a2a2a;
}

.nav-list li a.active {
    color: #2a2a2a;
    border-bottom-color: #F7C81A;
}

/* ===== CATEGORIES ===== */
.categories-section {
    background: #fff;
    padding: 12px 0;
    border-bottom: 1px solid #d9d9d9;
}

.categories-wrapper {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    scrollbar-width: thin;
}

.cat-btn {
    padding: 6px 18px;
    border: none;
    background: white;
    font-size: 12px;
    font-weight: 600;
    color: #5a5a5a;
    border-radius: 40px;
    white-space: nowrap;
    cursor: pointer;
    transition: 0.2s;
}

.cat-btn.active {
    background: #9e9e9e;
    color: white;
}

/* ===== HERO ===== */
.hero-banner {
    background: linear-gradient(135deg, #F7C81A 0%, #F7C81A 100%);
    padding: 40px 0;
    transition: background 0.3s ease;
}

.hero-tag {
    font-size: 13px;
    letter-spacing: 2px;
    font-weight: 700;
    color: #8a6d0b;
    margin-bottom: 8px;
    display: inline-block;
    background: rgba(255, 255, 255, 0.3);
    padding: 4px 16px;
    border-radius: 50px;
}

.hero-title {
    font-size: 38px;
    font-weight: 800;
    color: #2d2d2d;
    line-height: 1.2;
    margin-bottom: 16px;
}

.hero-title .highlight {
    color: #1a5276;
    position: relative;
}

.hero-title .highlight::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: #1a5276;
    border-radius: 2px;
}

.hero-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin: 16px 0;
}

.btn-hero-primary {
    background: #2a2a2a;
    color: white;
    border: none;
    padding: 12px 28px;
    border-radius: 50px;
    font-weight: 700;
    font-size: 16px;
    cursor: pointer;
    transition: 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.btn-hero-primary:hover {
    background: #1a1a1a;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
}

.btn-hero-secondary {
    background: transparent;
    color: #2a2a2a;
    border: 2px solid #2a2a2a;
    padding: 10px 28px;
    border-radius: 50px;
    font-weight: 700;
    font-size: 16px;
    cursor: pointer;
    transition: 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.btn-hero-secondary:hover {
    background: #2a2a2a;
    color: white;
    transform: translateY(-2px);
}

.trust-badges {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    margin-top: 20px;
}

.trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 500;
    color: #2d2d2d;
}

.trust-item i {
    font-size: 18px;
    color: #27ae60;
}

.fresh-card {
    background: white;
    padding: 24px 20px;
    border-radius: 24px;
    text-align: center;
    box-shadow: 0 20px 30px -10px rgba(0, 0, 0, 0.15);
}

.fresh-card h3 {
    font-weight: 800;
    font-size: 22px;
    margin-bottom: 8px;
}

.fresh-card p {
    color: #6a6a6a;
    margin-bottom: 16px;
}

.delivery-promise {
    margin-top: 16px;
    padding: 12px;
    background: #f8f8f8;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 14px;
}

.delivery-promise i {
    color: #F7C81A;
    font-size: 20px;
}

.delivery-promise strong {
    color: #2a2a2a;
}

.btn-start {
    background: #2a2a2a;
    border: none;
    padding: 12px 32px;
    border-radius: 50px;
    font-weight: 700;
    font-size: 16px;
    color: white;
    cursor: pointer;
    transition: 0.2s;
}

.btn-start:hover {
    background: #1a1a1a;
    transform: scale(1.02);
}

.stats-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin: 16px 0;
}

.stat-pill {
    background: rgba(45, 45, 45, 0.1);
    padding: 5px 14px;
    border-radius: 50px;
    font-weight: 700;
    font-size: 11px;
    color: #2d2d2d;
}

/* ===== PRODUCTS ===== */
.section-title {
    font-weight: 800;
    color: #2a2a2a;
    margin-bottom: 24px;
    font-size: 28px;
}

.product-card {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    transition: 0.3s;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
    height: 100%;
    padding: 18px 16px 20px;
    position: relative;
    border: 1px solid #e0e0e0;
    min-height: 380px;
}

.product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 25px -8px rgba(0, 0, 0, 0.15);
}

/* ===== PASTEL BADGE STYLES ===== */
.product-badge {
    position: absolute;
    top: 14px;
    right: 14px;
    padding: 5px 14px;
    border-radius: 30px;
    font-size: 11px;
    font-weight: 700;
    z-index: 3;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.2);
}

.product-badge:hover {
    transform: scale(1.05);
}

.badge-discount {
    background: #FFE0E0;
    color: #D63031;
    border-color: #FFCDCD;
}

.badge-bestseller {
    background: #E8D5F5;
    color: #6C3CE1;
    border-color: #DCC8ED;
}

.badge-limited {
    background: #FFE8D6;
    color: #E17055;
    border-color: #FFD4B8;
    animation: pulse-pastel 1.5s ease-in-out infinite;
}

.badge-new {
    background: #D4F5E9;
    color: #00B894;
    border-color: #B8EDDB;
}

.badge-top {
    background: #FFF3D6;
    color: #F39C12;
    border-color: #FFE8B8;
}

@keyframes pulse-pastel {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.03); }
}

.product-category-badge {
    position: absolute;
    top: 14px;
    left: 14px;
    background: rgba(0, 0, 0, 0.7);
    color: white;
    font-size: 9px;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 30px;
    z-index: 2;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
}

.product-category-badge:hover {
    transform: scale(1.05);
}

.produce-badge {
    background: #E8D5C4;
    color: #8B5E3C;
}

.meat-badge {
    background: #F5D4D4;
    color: #B8422E;
}

.bakery-badge {
    background: #F5E6D4;
    color: #C26A2E;
}

.frozen-badge {
    background: #D4E8E8;
    color: #2E8B8B;
}

.beverages-badge {
    background: #E0D4E8;
    color: #7A5A8E;
}

.household-badge {
    background: #E0E0E0;
    color: #5A5A5A;
}

.product-img-wrapper {
    width: 100%;
    height: 160px;
    overflow: hidden;
    border-radius: 16px;
    margin-bottom: 12px;
    background: #f5f5f5;
}

.product-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.product-name {
    font-size: 17px;
    font-weight: 800;
    color: #2a2a2a;
    margin-bottom: 4px;
    line-height: 1.3;
}

.product-price-wrapper {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 3px;
}

.product-price {
    font-size: 22px;
    font-weight: 800;
    color: #2a2a2a;
}

.product-price-original {
    font-size: 16px;
    color: #999;
    text-decoration: line-through;
}

.product-rating {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 15px;
    color: #f39c12;
    margin: 5px 0 8px;
}

.product-rating .bi-star-fill,
.product-rating .bi-star-half {
    color: #f39c12;
    font-size: 16px;
}

.product-rating .bi-star {
    color: #ddd;
    font-size: 16px;
}

.product-rating span {
    color: #666;
    font-weight: 600;
}

.review-count {
    color: #999 !important;
    font-weight: 400 !important;
    font-size: 13px;
}

.stock-warning {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    color: #e74c3c;
    margin: 4px 0;
    padding: 3px 12px;
    background: #fde8e8;
    border-radius: 12px;
}

.product-desc {
    font-size: 13px;
    color: #8a8a8a;
    margin: 6px 0 12px;
    line-height: 1.5;
}

.product-actions {
    display: flex;
    gap: 10px;
}

.btn-details,
.btn-add-cart {
    flex: 1;
    padding: 8px 0;
    border-radius: 40px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    transition: 0.2s;
}

.btn-details {
    background: transparent;
    border: 2px solid #d9d9d9;
    color: #6a6a6a;
}

.btn-details:hover {
    background: #f0f0f0;
}

.btn-add-cart {
    background: #2a2a2a;
    border: none;
    color: white;
    font-size: 13px;
}

.btn-add-cart:hover {
    background: #1a1a1a;
    transform: scale(1.02);
}

.btn-add-cart:disabled {
    background: #999;
    cursor: not-allowed;
    transform: none;
}

/* ===== PAGE CONTAINER (Contact + FAQ) ===== */
.page-container {
    padding: 40px 0 60px;
    background: #ffffff;
}

.page-header {
    text-align: center;
    margin-bottom: 40px;
}

.page-header h1 {
    font-weight: 800;
    color: #2a2a2a;
    font-size: 32px;
}

.page-header h1 i {
    color: #F7C81A;
}

.page-header p {
    color: #6a6a6a;
    font-size: 16px;
}

/* ===== CONTACT ===== */
.contact-form-wrapper {
    background: #f8f8f8;
    padding: 30px;
    border-radius: 20px;
}

.contact-form-wrapper h3 {
    font-weight: 700;
    margin-bottom: 20px;
}

.contact-form-wrapper .form-control {
    border-radius: 12px;
    border: 1.5px solid #e0e0e0;
    padding: 12px 16px;
    transition: background 0.3s, color 0.3s, border-color 0.3s;
}

.contact-form-wrapper .form-control:focus {
    border-color: #F7C81A;
    box-shadow: 0 0 0 3px rgba(247, 200, 26, 0.2);
}

.btn-submit {
    background: #2a2a2a;
    color: white;
    border: none;
    padding: 12px 32px;
    border-radius: 50px;
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
    transition: 0.2s;
}

.btn-submit:hover {
    background: #1a1a1a;
    transform: scale(1.02);
}

.contact-info-wrapper {
    padding: 30px;
}

.contact-info-wrapper h3 {
    font-weight: 700;
    margin-bottom: 24px;
}

.contact-info-item {
    display: flex;
    gap: 16px;
    margin-bottom: 20px;
}

.contact-info-item i {
    font-size: 24px;
    color: #F7C81A;
    width: 40px;
    height: 40px;
    background: #f8f8f8;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    transition: background 0.3s;
}

.contact-info-item h6 {
    font-weight: 700;
    margin-bottom: 4px;
}

.contact-info-item p {
    color: #6a6a6a;
    margin: 0;
}

.social-links {
    margin-top: 24px;
}

.social-links h6 {
    font-weight: 700;
    margin-bottom: 12px;
}

.social-icons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
}

.social-icons a {
    width: 40px;
    height: 40px;
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    color: #4a4a4a;
    text-decoration: none;
    transition: 0.2s;
}

.social-icons a:hover {
    background: #F7C81A;
    color: white;
    transform: translateY(-2px);
}

/* ===== FAQ ===== */
.faq-search-wrapper {
    max-width: 600px;
    margin: 0 auto 40px;
}

.faq-search-box {
    position: relative;
}

.faq-search-box i {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: #8a8a8a;
}

.faq-search-box input {
    width: 100%;
    padding: 14px 16px 14px 48px;
    border: 2px solid #e0e0e0;
    border-radius: 50px;
    font-size: 14px;
    transition: 0.2s;
}

.faq-search-box input:focus {
    outline: none;
    border-color: #F7C81A;
    box-shadow: 0 0 0 3px rgba(247, 200, 26, 0.2);
}

.faq-category {
    margin-bottom: 32px;
}

.faq-category h3 {
    font-weight: 700;
    color: #2a2a2a;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 2px solid #f0f0f0;
}

.faq-category h3 i {
    color: #F7C81A;
    margin-right: 10px;
}

.faq-item {
    background: #f8f8f8;
    border-radius: 12px;
    margin-bottom: 10px;
    overflow: hidden;
}

.faq-question {
    padding: 16px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    transition: 0.2s;
}

.faq-question:hover {
    background: #f0f0f0;
}

.faq-question span {
    font-weight: 600;
    color: #2a2a2a;
}

.faq-question i {
    transition: 0.3s;
    color: #6a6a6a;
}

.faq-item.active .faq-question i {
    transform: rotate(180deg);
}

.faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
    padding: 0 20px;
}

.faq-item.active .faq-answer {
    max-height: 300px;
    padding: 0 20px 16px;
}

.faq-answer p {
    color: #4a4a4a;
    margin: 0;
    line-height: 1.6;
}

/* ===== CART SIDEBAR ===== */
.cart-sidebar {
    position: fixed;
    top: 0;
    right: -400px;
    width: 380px;
    max-width: 90vw;
    height: 100vh;
    background: white;
    box-shadow: -5px 0 25px rgba(0, 0, 0, 0.2);
    z-index: 1050;
    transition: right 0.3s ease;
    display: flex;
    flex-direction: column;
}

.cart-sidebar.active {
    right: 0;
}

.cart-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1040;
    display: none;
}

.cart-overlay.active {
    display: block;
}

.cart-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px;
    border-bottom: 2px solid #f0f0f0;
    background: white;
}

.cart-header h5 {
    font-weight: 800;
    margin: 0;
}

.close-cart-btn {
    background: none;
    border: none;
    font-size: 20px;
    cursor: pointer;
    color: #666;
}

.cart-items-container {
    flex: 1;
    overflow-y: auto;
    padding: 15px;
}

.cart-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 0;
    border-bottom: 1px solid #eee;
}

.cart-item-info {
    flex: 1;
}

.cart-item-name {
    font-weight: 700;
    font-size: 14px;
    margin-bottom: 4px;
}

.cart-item-price {
    font-size: 12px;
    color: #6a6a6a;
}

.cart-item-actions {
    display: flex;
    align-items: center;
    gap: 12px;
}

.qty-btn {
    background: #f0f0f0;
    border: none;
    width: 28px;
    height: 28px;
    border-radius: 8px;
    font-weight: bold;
    cursor: pointer;
    transition: 0.2s;
}

.qty-btn:hover {
    background: #e0e0e0;
}

.cart-item-qty {
    font-weight: 600;
    min-width: 30px;
    text-align: center;
}

.remove-item-btn {
    background: none;
    border: none;
    color: #e74c3c;
    cursor: pointer;
    font-size: 18px;
    margin-left: 8px;
}

.empty-cart {
    text-align: center;
    padding: 40px;
    color: #999;
}

.cart-footer {
    padding: 20px;
    border-top: 2px solid #f0f0f0;
    background: white;
}

.cart-total-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 10px;
    font-size: 14px;
}

.total-price-row {
    font-weight: 800;
    font-size: 18px;
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px dashed #ddd;
}

.checkout-btn {
    width: 100%;
    padding: 12px;
    background: #2a2a2a;
    color: white;
    border: none;
    border-radius: 50px;
    font-weight: 700;
    margin-top: 10px;
    cursor: pointer;
    transition: 0.2s;
}

.checkout-btn:hover {
    background: #1a1a1a;
}

/* ===== TOAST ===== */
.toast-message {
    position: fixed;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: #2a2a2a;
    color: white;
    padding: 10px 24px;
    border-radius: 50px;
    font-size: 14px;
    font-weight: 500;
    z-index: 1100;
    transition: 0.3s;
    opacity: 0;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
}

.toast-message.show {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
}

/* ===== FOOTER ===== */
.footer {
    background: #2a2a2a;
    color: #d9d9d9;
    padding: 50px 0 24px;
    margin-top: 40px;
}

.footer-logo {
    font-size: 20px;
    font-weight: 800;
    margin-bottom: 10px;
    color: #e0e0e0;
}

.footer-text {
    color: #b0b0b0;
    font-size: 13px;
    line-height: 1.6;
}

.footer h6 {
    color: #e0e0e0;
    font-weight: 700;
    margin-bottom: 14px;
    font-size: 14px;
}

.footer ul li {
    margin-bottom: 8px;
}

.footer ul li a {
    color: #b0b0b0;
    text-decoration: none;
    font-size: 13px;
    transition: 0.2s;
}

.footer ul li a:hover {
    color: #F7C81A;
    padding-left: 5px;
}

.footer .social-icons a {
    width: 36px;
    height: 36px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #d9d9d9;
    text-decoration: none;
    transition: 0.2s;
}

.footer .social-icons a:hover {
    background: #F7C81A;
    color: #2a2a2a;
    transform: translateY(-3px);
}

.app-download-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.1);
    color: #d9d9d9;
    padding: 8px 16px;
    border-radius: 8px;
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    transition: 0.2s;
}

.app-download-btn:hover {
    background: #F7C81A;
    color: #2a2a2a;
}

.footer-divider {
    border-color: rgba(255, 255, 255, 0.1);
    margin: 24px 0 16px;
}

.copyright {
    color: #9a9a9a;
    font-size: 12px;
    text-align: center;
}

/* ===== SCROLL SPACING ===== */
section {
    scroll-margin-top: 130px;
}

