* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Inter', sans-serif;
    background: #f5f5f5;
    overflow-x: hidden;
    scroll-behavior: smooth;
    transition: background 0.3s ease, color 0.3s ease;
}

